# Default approach (soft failure)
def _transfer_error(status_logger, message, reason=None, **fields):
    if status_logger:
        status_logger.log_error(message, reason=reason or message, **fields)
    else:
        # Log to stderr but don't fail
        sys.stderr.write(f"[STATUS_LOGGER_UNAVAILABLE] {message}\n")
        
        # Optional: Add to environment variable to control behavior
        if os.environ.get('FAIL_ON_MISSING_LOGGER', 'false').lower() == 'true':
            raise RuntimeError("Status logger was not available")


