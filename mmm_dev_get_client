def lambda_handler(event, context):
    """
    Main Lambda handler.
    
    Input: Event from EventBridge or Step Function
    Output: Dict with list of active clients and metadata
    """
    execution_id = getattr(context, "aws_request_id", None) or "local"
    env_tag = os.environ.get("ENVIRONMENT", "dev")

    run_log = {
        "event": event,
        "status": "started",
        "timestamp": str(datetime.now(timezone.utc)),
        "function": "mmm_dev_get_client",
        "configuration": {
            "data_table": DATA_TABLE,
            "s3_log_bucket": S3_LOG_BUCKET,
            "aws_region": AWS_REGION
        }
    }

    # MikAura observability (pipeline-agnostic)
    status_logger = None
    metric_logger = None
    if _MIKAURA_AVAILABLE:
        _config = MikAuraObservabilityConfig(
            context={"pipeline_context": "Data Ingestion Pipeline"},
            environment=env_tag,
            correlation_id=execution_id,
        )
        status_logger = MikAuraStatusLogger.from_config(
            _config,
            min_level=LOG_LEVEL,
            allowed_statuses=set(GET_CLIENT_ALLOWED_STATUSES),
        )
        metric_logger = MikAuraMetricLogger.from_config(_config)

    with ingestion_context(
        use_case="get_active_clients",
        pipeline_component="get_client_lambda",
        execution_id=execution_id,
        environment=env_tag,
    ):
        try:
            _get_client_running(
                status_logger,
                "Starting mmm_dev_get_client Lambda execution",
            )

            table = validate_table_exists(status_logger)
            items = fetch_metadata_active_clients(table, status_logger)

            if not items:
                _get_client_warning(
                    status_logger,
                    "No active clients found in metadata table",
                    rows_returned=0,
                )
                run_log.update({
                    "status": "no_active_clients",
                    "rows_returned": 0,
                    "message": "No active clients found in metadata table",
                    "timestamp": str(datetime.now(timezone.utc))
                })
                write_log_to_s3(run_log, status_logger)
                if metric_logger:
                    metric_logger.increment("data_ingestion.get_client.outcome", extra_tags=["result:no_active_clients"])
                elif _get_client_metrics:
                    _get_client_metrics.increment(
                        "data_ingestion.get_client.outcome",
                        tags=[f"env:{env_tag}", "result:no_active_clients"],
                    )
                return {
                    "clients": [],
                    "status": "no_active_clients",
                    "message": "No active clients found in metadata table",
                    "rows_returned": 0,
                    "timestamp": str(datetime.now(timezone.utc))
                }

            clients = format_client_metadata(items, status_logger)

            run_log.update({
                "status": "success",
                "rows_returned": len(clients),
                "timestamp": str(datetime.now(timezone.utc))
            })

            write_log_to_s3(run_log, status_logger)

            _get_client_success(
                status_logger,
                f"Retrieved {len(clients)} active clients",
                rows_returned=len(clients),
            )
            if metric_logger:
                metric_logger.increment("data_ingestion.get_client.outcome", extra_tags=["result:success"])
            elif _get_client_metrics:
                _get_client_metrics.increment(
                    "data_ingestion.get_client.outcome",
                    tags=[f"env:{env_tag}", "result:success"],
                )

            return {
                "clients": clients,
                "status": "success",
                "rows_returned": len(clients),
                "timestamp": str(datetime.now(timezone.utc))
            }

        except Exception as e:
            run_log.update({
                "status": "failed",
                "error": str(e),
                "traceback": traceback.format_exc(),
                "timestamp": str(datetime.now(timezone.utc))
            })

            write_log_to_s3(run_log, status_logger)

            _get_client_exception(status_logger, "Lambda execution failed", e)
            if metric_logger:
                metric_logger.increment("data_ingestion.get_client.outcome", extra_tags=["result:failed"])
            elif _get_client_metrics:
                _get_client_metrics.increment(
                    "data_ingestion.get_client.outcome",
                    tags=[f"env:{env_tag}", "result:failed"],
                )

            raise RuntimeError(f"Lambda execution failed: {e}")
