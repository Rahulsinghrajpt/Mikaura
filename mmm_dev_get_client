def write_log_to_s3(log_data: dict, status_logger: Optional[Any] = None) -> None:
    """Write execution log to S3 bucket for audit trail."""
    try:
        key = f"{S3_PREFIX}log_{datetime.now(timezone.utc).strftime('%Y%m%d_%H%M%S_%f')}.json"
        s3_client.put_object(
            Bucket=S3_LOG_BUCKET,
            Key=key,
            Body=json.dumps(log_data, indent=2),
            ContentType="application/json"
        )
        _get_client_debug(
            status_logger,
            f"Log written to S3: s3://{S3_LOG_BUCKET}/{key}",
            s3_bucket=S3_LOG_BUCKET,
            s3_key=key,
        )
    except Exception as e:
        if status_logger:
            _get_client_warning(
                status_logger,
                "Failed to write audit log to S3",
                reason=str(e),
            )
        else:
            logger.error(f"[S3 Logging Error] Failed to write log to S3: {e}")
        # Don't raise - logging failure shouldn't fail the Lambda


def validate_table_exists(status_logger: Optional[Any] = None):
    """Validate that DynamoDB table exists."""
    try:
        table = dynamodb.Table(DATA_TABLE)
        # Attempt to access table metadata
        table.table_status
        _get_client_info(
            status_logger,
            "DynamoDB table verified",
            data_table=DATA_TABLE,
            force=True,
        )
        return table
    except ClientError as e:
        if e.response['Error']['Code'] == 'ResourceNotFoundException':
            error_msg = f"DynamoDB table not found: {DATA_TABLE}"
            _get_client_error(status_logger, error_msg, reason=error_msg, data_table=DATA_TABLE)
            raise RuntimeError(error_msg)
        else:
            raise


def fetch_metadata_active_clients(table, status_logger: Optional[Any] = None):
    """Fetch all active clients from pipeline-infos DynamoDB table.
    
    Uses scan with filter since the table may not have the ActiveClientsIndex GSI.
    For production with large tables, consider adding the GSI for better performance.
    """
    try:
        _get_client_info(
            status_logger,
            "Scanning pipeline-infos for active clients",
            data_table=DATA_TABLE,
            force=True,
        )
        # Scan with filter for active clients
        # is_active can be 1, "1", True, "ACTIVE", or "active"
        # Using scan instead of GSI query for compatibility with tables without GSI
        response = table.scan()
        all_items = response.get("Items", [])
        
        # Handle pagination if needed
        while "LastEvaluatedKey" in response:
            response = table.scan(
                ExclusiveStartKey=response["LastEvaluatedKey"]
            )
            all_items.extend(response.get("Items", []))
        
        # Filter for active clients in Python
        items = []
        for item in all_items:
            is_active = item.get('is_active')
            # Check if active (is_active can be 1, "1", True, or "ACTIVE")
            if is_active in [1, '1', True, 'ACTIVE', 'active']:
                items.append(item)
        
        _get_client_info(
            status_logger,
            "Filtered active clients",
            data_table=DATA_TABLE,
            rows_returned=len(items),
            total_scanned=len(all_items),
            force=True,
        )
        return items
    except Exception as e:
        error_info = {
            "stage": "fetch_active_clients",
            "table": DATA_TABLE,
            "error": str(e),
            "traceback": traceback.format_exc()
        }
        _get_client_error(
            status_logger,
            f"Error fetching active clients: {e}",
            reason=str(e),
            data_table=DATA_TABLE,
        )
        write_log_to_s3(error_info, status_logger)
        raise RuntimeError(f"Error in fetching metadata from DynamoDB: {e}")


def format_client_metadata(items, status_logger: Optional[Any] = None):
    """Format pipeline-infos items for Step Function Map state."""
    try:
        clients = []
        for item in items:
            # Parse brand_retailer_key to extract brand_id and retailer_id
            # CRITICAL: brand_retailer_key format is {brand_id}#{retailer_id}, not {brand_name}#{retailer_id}
            brand_retailer_key = item.get("brand_retailer_key", "")
            if "#" in brand_retailer_key:
                brand_id, retailer_id = brand_retailer_key.split("#", 1)
            else:
                brand_id = item.get("brand_id", "")
                retailer_id = item.get("retailer_id", "")
            
            # Use retailer_id from item if available, otherwise use parsed value
            final_retailer_id = item.get("retailer_id", retailer_id)
            
            # National retailer is now supported with separate processing logic
            # The data_transfer Lambda will detect National files and process them separately
            # to prevent fan-out and drop retailer-specific columns appropriately
            
            client_info = {
                "client_id": item.get("client_id"),
                "client_name": item.get("client_name"),
                "brand_id": item.get("brand_id", brand_id),  # Use split value as fallback
                "brand_name": item.get("brand_name"),  # Always use DynamoDB value, no fallback
                "retailer_id": final_retailer_id,
                "retailer_name": item.get("retailer_name"),
                "region": item.get("region", AWS_REGION),  # Default to Lambda region
                "last_trained_date": item.get("last_trained_date"),
                "next_training_due": item.get("next_training_due"),
                "brand_retailer_key": brand_retailer_key  # Include for data_transfer Lambda
            }
            clients.append(client_info)
        
        _get_client_info(
            status_logger,
            "Formatted client metadata for Step Function",
            rows_returned=len(clients),
            force=True,
        )
        return clients
    except Exception as e:
        error_info = {
            "stage": "format_clients",
            "error": str(e),
            "traceback": traceback.format_exc()
        }
        _get_client_error(
            status_logger,
            f"Error formatting client metadata: {e}",
            reason=str(e),
        )
        write_log_to_s3(error_info, status_logger)
        raise RuntimeError(f"Error in formatting client metadata: {e}")


